{:feature "Step definitions",
 :scenarios
 [{:steps
   [{:type :given,
     :text
     "a given step named \"add-timeout\" with template \"timeout is {seconds:int}\""}
    {:type :then,
     :text
     "the step \"add-timeout\" should be registered as a :given step"}
    {:type :and,
     :text "the step \"add-timeout\" should match \"timeout is 300\""}
    {:type :and, :text "the match args should be [300]"}],
   :scenario "Define a given step with integer capture"}
  {:steps
   [{:type :given,
     :text
     "a when step named \"run-action\" with template \"running the action\""}
    {:type :then,
     :text
     "the step \"run-action\" should be registered as a :when step"}
    {:type :and,
     :text
     "the step \"run-action\" should match \"running the action\""}
    {:type :and, :text "the match args should be []"}],
   :scenario "Define a when step with no captures"}
  {:steps
   [{:type :given,
     :text
     "a then step named \"check-status\" with template \"the status should be {status}\""}
    {:type :then,
     :text
     "the step \"check-status\" should be registered as a :then step"}
    {:type :and,
     :text
     "the step \"check-status\" should match \"the status should be active\""}
    {:type :and, :text "the match args should be [\"active\"]"}],
   :scenario "Define a then step with word capture"}
  {:steps
   [{:type :given,
     :text
     "a given step named \"add-timeout\" with template \"timeout is {seconds:int}\""}
    {:type :when,
     :text "classifying \"something completely unrecognized\""}
    {:type :then, :text "no step should match"}],
   :scenario "Unrecognized step text returns no match"}],
 :description
 "Steps are the building blocks of Gherkin scenarios. Each step\nis defined with defgiven, defwhen, or defthen and maps a\ntemplate string to a callable function.",
 :source "step_definitions.feature"}
