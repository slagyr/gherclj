{:feature "Step patterns",
 :scenarios
 [{:steps
   [{:type :given,
     :text
     "a given step named \"greet\" with template \"hello \\\"{name}\\\"\""}
    {:type :then,
     :text "the step \"greet\" should match \"hello \\\"Alice\\\"\""}
    {:type :and, :text "the match args should be [\"Alice\"]"}],
   :scenario "Quoted string capture"}
  {:steps
   [{:type :given,
     :text
     "a then step named \"check-price\" with template \"the price is {amount:float}\""}
    {:type :then,
     :text
     "the step \"check-price\" should match \"the price is 19.99\""}
    {:type :and, :text "the match args should be [19.99]"}],
   :scenario "Float capture"}
  {:steps
   [{:type :given,
     :text
     "a given step named \"set-config\" with template \"set \\\"{key}\\\" to {value:int}\""}
    {:type :then,
     :text
     "the step \"set-config\" should match \"set \\\"timeout\\\" to 300\""}
    {:type :and, :text "the match args should be [\"timeout\" 300]"}],
   :scenario "Multiple captures of different types"}
  {:steps
   [{:type :given,
     :text
     "a given step named \"parens\" with template \"call foo() with {n:int} args\""}
    {:type :then,
     :text
     "the step \"parens\" should match \"call foo() with 3 args\""}
    {:type :and, :text "the match args should be [3]"}],
   :scenario "Template escapes regex special characters"}
  {:steps
   [{:type :given, :text "the registered step \"raw-output-match\""}
    {:type :then,
     :text
     "the step \"raw-output-match\" should match \"the output contains hello world\""}
    {:type :and, :text "the match args should be [\"hello world\"]"}],
   :scenario "Macro accepts a raw regex pattern"}
  {:steps
   [{:type :given, :text "the registered step \"raw-digit-match\""}
    {:type :then,
     :text "the step \"raw-digit-match\" should match \"count is 42\""}
    {:type :and, :text "the match args should be [\"42\"]"}],
   :scenario "Regex captures are strings, not coerced"}],
 :description
 "Step definitions accept either a template string or a raw regex.\nTemplates offer convenience with typed captures; regexes offer\nfull control without coercion.",
 :source "step_patterns.feature"}
