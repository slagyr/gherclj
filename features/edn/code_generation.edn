{:feature "Code generation",
 :scenarios
 [{:steps
   [{:type :given,
     :text
     "a feature named \"Authentication\" from source \"auth.feature\""}
    {:type :and,
     :text "a scenario \"User can log in\" with steps:",
     :table
     {:headers ["type" "text"],
      :rows
      [["given" "timeout is 300"]
       ["when" "running the action"]
       ["then" "the status should be active"]]}}
    {:type :when, :text "generating the spec with framework :speclj"}
    {:type :then, :text "the output should contain \"Authentication\""}
    {:type :and, :text "the output should contain \"User can log in\""}
    {:type :and, :text "the output should contain \"add-timeout 300\""}
    {:type :and, :text "the output should contain \"run-action\""}],
   :scenario "Generate a spec from a simple feature"}
  {:steps
   [{:type :given,
     :text
     "a feature named \"Pending\" from source \"pending.feature\""}
    {:type :and,
     :text "a scenario \"Not yet done\" with steps:",
     :table
     {:headers ["type" "text"],
      :rows
      [["given" "something not yet defined"]
       ["when" "doing the undefined thing"]]}}
    {:type :when, :text "generating the spec with framework :speclj"}
    {:type :then, :text "the output should contain \"pending\""}],
   :scenario "Unrecognized steps generate pending scenarios"}],
 :description
 "The generator takes parsed feature IR and registered steps\nand produces runnable spec files with qualified function calls.",
 :source "code_generation.feature"}
