{:feature "IR to code generation",
 :scenarios
 [{:steps
   [{:type :given,
     :text "a feature named \"Login\" from source \"login.feature\""}
    {:type :and,
     :text "a scenario \"Valid credentials\" with steps:",
     :table
     {:headers ["type" "text"],
      :rows
      [["given" "a user \"alice\""]
       ["when" "the user logs in"]
       ["then" "the response should be 200"]]}}
    {:type :when, :text "generating the spec with framework :speclj"}
    {:type :then, :text "the generated code should be:"}],
   :scenario "Generate a speclj spec"}
  {:steps
   [{:type :given,
     :text "a feature named \"Login\" from source \"login.feature\""}
    {:type :and,
     :text "a scenario \"Valid credentials\" with steps:",
     :table
     {:headers ["type" "text"],
      :rows
      [["given" "a user \"alice\""]
       ["when" "the user logs in"]
       ["then" "the response should be 200"]]}}
    {:type :when,
     :text "generating the spec with framework :clojure.test"}
    {:type :then, :text "the generated code should be:"}],
   :scenario "Generate a clojure.test spec"}
  {:steps
   [{:type :given,
     :text "a feature named \"Login\" from source \"login.feature\""}
    {:type :and,
     :text "a background with steps:",
     :table
     {:headers ["type" "text"], :rows [["given" "a user \"alice\""]]}}
    {:type :and,
     :text "a scenario \"First\" with steps:",
     :table
     {:headers ["type" "text"], :rows [["when" "the user logs in"]]}}
    {:type :and,
     :text "a scenario \"Second\" with steps:",
     :table
     {:headers ["type" "text"],
      :rows [["then" "the response should be 200"]]}}
    {:type :when, :text "generating the spec with framework :speclj"}
    {:type :then,
     :text
     "the output should contain \"(sample-app/create-user \\\"alice\\\")\""}
    {:type :and,
     :text "the output should contain \"(sample-app/user-logs-in)\""}
    {:type :and,
     :text
     "the output should contain \"(sample-app/response-should-be 200)\""}],
   :scenario "Background steps are included in every scenario"}
  {:steps
   [{:type :given,
     :text "a feature named \"Login\" from source \"login.feature\""}
    {:type :and,
     :text "a scenario \"First\" with steps:",
     :table
     {:headers ["type" "text"], :rows [["when" "the user logs in"]]}}
    {:type :and,
     :text "a scenario \"Second\" with steps:",
     :table
     {:headers ["type" "text"], :rows [["when" "the user logs in"]]}}
    {:type :when, :text "generating the spec with framework :speclj"}
    {:type :then, :text "the output should contain \"(h/reset!)\""}],
   :scenario "Harness reset is called before each scenario"}
  {:steps
   [{:type :given,
     :text "a feature named \"Login\" from source \"login.feature\""}
    {:type :and,
     :text "a scenario \"Not implemented\" with steps:",
     :table
     {:headers ["type" "text"],
      :rows
      [["given" "something undefined"]
       ["when" "doing unknown things"]]}}
    {:type :when, :text "generating the spec with framework :speclj"}
    {:type :then, :text "the output should contain \"pending\""}
    {:type :and,
     :text
     "the output should contain \";; given something undefined\""}],
   :scenario "Unrecognized steps generate pending scenarios"}
  {:steps
   [{:type :given,
     :text "a feature named \"Login\" from source \"login.feature\""}
    {:type :and,
     :text "a scenario \"Normal\" with steps:",
     :table
     {:headers ["type" "text"], :rows [["when" "the user logs in"]]}}
    {:type :and,
     :text "a wip scenario \"Skipped\" with steps:",
     :table
     {:headers ["type" "text"],
      :rows [["given" "something undefined"]]}}
    {:type :when, :text "generating the spec with framework :speclj"}
    {:type :then, :text "the output should contain \"Normal\""}
    {:type :and, :text "the output should not contain \"Skipped\""}],
   :scenario "WIP scenarios are excluded from generation"}],
 :description
 "The generator converts parsed feature IR into executable spec files.\nIt resolves steps to qualified function calls and delegates formatting\nto framework-specific multimethods.",
 :source "ir_to_code.feature"}
