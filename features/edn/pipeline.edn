{:feature "Pipeline",
 :scenarios
 [{:steps
   [{:type :given,
     :text "a features directory containing:",
     :table
     {:headers ["file"],
      :rows [["login.feature"] ["checkout.feature"]]}}
    {:type :and, :text "the feature \"login.feature\" contains:"}],
   :scenario "Parse stage writes EDN IR files"}
  {:steps
   [{:type :given, :text "a valid user"}
    {:type :when, :text "the user logs in"}
    {:type :then, :text "the user sees the dashboard"}
    {:type :and, :text "the feature \"checkout.feature\" contains:"}],
   :scenario "Valid credentials"}
  {:steps
   [{:type :given, :text "an empty cart"}
    {:type :when, :text "the user checks out"}
    {:type :then, :text "an error is shown"}
    {:type :when, :text "the parse stage runs"}
    {:type :then,
     :text "\"target/gherclj/edn/login.edn\" should exist"}
    {:type :and,
     :text "\"target/gherclj/edn/checkout.edn\" should exist"}
    {:type :and,
     :text "\"target/gherclj/edn/login.edn\" should contain IR:"}],
   :scenario "Empty cart"}
  {:steps
   [{:type :given,
     :text "a features directory containing:",
     :table {:headers ["file"], :rows [["auth.feature"]]}}
    {:type :and, :text "the feature \"auth.feature\" contains:"}],
   :scenario "Pipeline is silent by default"}
  {:steps
   [{:type :given, :text "a user"}
    {:type :when,
     :text "the full pipeline runs with framework :speclj"}
    {:type :then, :text "the output should be empty"}],
   :scenario "Login"}
  {:steps
   [{:type :given,
     :text "a features directory containing:",
     :table {:headers ["file"], :rows [["auth.feature"]]}}
    {:type :and, :text "the feature \"auth.feature\" contains:"}],
   :scenario "Parse stage reports progress when verbose"}
  {:steps [{:type :given, :text "a user"}], :scenario "Login"}
  {:steps
   [{:type :given, :text "a session"}
    {:type :when, :text "the parse stage runs with :verbose"}
    {:type :then,
     :text
     "the output should contain \"Parsing auth.feature -> target/gherclj/edn/auth.edn\""}
    {:type :and,
     :text "the output should contain \"2 scenarios parsed\""}],
   :scenario "Logout"}
  {:steps
   [{:type :given,
     :text "a features directory containing:",
     :table {:headers ["file"], :rows [["auth.feature"]]}}
    {:type :and, :text "the feature \"auth.feature\" contains:"}],
   :scenario "Generate stage writes spec files from EDN"}
  {:steps
   [{:type :given, :text "a valid user"}
    {:type :and, :text "the parse stage has run"}
    {:type :when,
     :text "the generate stage runs with framework :speclj"}
    {:type :then,
     :text "\"target/gherclj/generated/auth_spec.clj\" should exist"}
    {:type :and,
     :text
     "\"target/gherclj/generated/auth_spec.clj\" should contain \"(describe \\\"Auth\\\"\""}],
   :scenario "Login"}
  {:steps
   [{:type :given,
     :text "a features directory containing:",
     :table {:headers ["file"], :rows [["auth.feature"]]}}
    {:type :and, :text "the feature \"auth.feature\" contains:"}],
   :scenario "Generate stage reports progress when verbose"}
  {:steps
   [{:type :given, :text "a valid user"}
    {:type :and, :text "the parse stage has run"}
    {:type :when,
     :text
     "the generate stage runs with framework :speclj and :verbose"}
    {:type :then,
     :text
     "the output should contain \"Generating target/gherclj/generated/auth_spec.clj from auth.edn\""}
    {:type :and,
     :text "the output should contain \"1 scenarios generated\""}],
   :scenario "Login"}
  {:steps
   [{:type :given,
     :text "a features directory containing:",
     :table {:headers ["file"], :rows [["auth.feature"]]}}
    {:type :and, :text "the feature \"auth.feature\" contains:"}],
   :scenario "Full pipeline runs both stages"}
  {:steps
   [{:type :given, :text "a valid user"}
    {:type :when,
     :text "the full pipeline runs with framework :speclj"}
    {:type :then, :text "\"target/gherclj/edn/auth.edn\" should exist"}
    {:type :and,
     :text "\"target/gherclj/generated/auth_spec.clj\" should exist"}],
   :scenario "Login"}
  {:steps
   [{:type :given,
     :text "a features directory containing:",
     :table {:headers ["file"], :rows [["auth.feature"]]}}
    {:type :and, :text "the feature \"auth.feature\" contains:"}],
   :scenario "WIP scenarios are parsed but not generated"}
  {:steps [{:type :given, :text "something"}],
   :scenario "Not ready",
   :wip true}
  {:steps
   [{:type :given, :text "a valid user"}
    {:type :when,
     :text "the full pipeline runs with framework :speclj"}
    {:type :then,
     :text
     "\"target/gherclj/edn/auth.edn\" should contain IR with 2 scenarios"}
    {:type :and,
     :text
     "\"target/gherclj/generated/auth_spec.clj\" should contain \"Ready\""}
    {:type :and,
     :text
     "\"target/gherclj/generated/auth_spec.clj\" should not contain \"Not ready\""}],
   :scenario "Ready"}],
 :description
 "The pipeline orchestrates parsing and code generation as a\ntwo-stage flow, writing intermediate and final artifacts to\nthe target directory.",
 :source "pipeline.feature"}
